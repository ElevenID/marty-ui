# Cloudflare Tunnel Environment Configuration
# =============================================
#
# Copy this file to .env.tunnel and fill in your values:
#   cp .env.tunnel.example .env.tunnel
#
# IMPORTANT: Add .env.tunnel to .gitignore to prevent committing secrets!
#
# To get your tunnel token:
#   1. Go to Cloudflare Dashboard → Zero Trust → Networks → Tunnels
#   2. Create a tunnel or select existing
#   3. Copy the token from the setup instructions

# =============================================================================
# Cloudflare Tunnel Token (REQUIRED)
# =============================================================================
# Your unique tunnel token from Cloudflare
# Format: Long base64 string starting with "eyJ..."
# Example: eyJhIjoiYWJjZGVmZ2hpamtsbW5vcHFyc3R1dnd4eXoxMjM0NTY3ODkwIiwidCI6ImFiY2RlZmdoaWprbG1ub3BxcnN0dXZ3eHl6MTIzNDU2Nzg5MCIsInMiOiJhYmNkZWZnaGlqa2xtbm9wcXJzdHV2d3h5ejEyMzQ1Njc4OTAifQ==
CLOUDFLARE_TUNNEL_TOKEN=

# =============================================================================
# Public URLs
# =============================================================================
# The public domain where ElevenID will be accessible (without https://)
# This should match what you configured in Cloudflare tunnel
PUBLIC_DOMAIN=beta.elevenidllc.com

# The public URL where ElevenID will be accessible
PUBLIC_URL=https://beta.elevenidllc.com

# API URL - can be same as PUBLIC_URL if nginx proxies /api/* requests
PUBLIC_API_URL=https://beta.elevenidllc.com

# Environment name (for display/logging)
ENVIRONMENT=tunnel

# =============================================================================
# Security Settings (HTTPS)
# =============================================================================
# Enable secure cookies (required for HTTPS)
COOKIE_SECURE=true

# SameSite cookie policy
# Options: none, lax, strict
# "none" required for cross-site requests with HTTPS
COOKIE_SAMESITE=none

# HSTS (HTTP Strict Transport Security)
# Usually handled by Cloudflare, set to false unless you need it upstream
HSTS_ENABLED=false

# =============================================================================
# CORS Configuration
# =============================================================================
# Allowed origins for CORS (comma-separated)
# Include your public domain and localhost for development
CORS_ORIGINS=https://beta.elevenfold.com,http://localhost:9080,http://localhost:3000

# =============================================================================
# Session Configuration
# =============================================================================
# Session cookie domain (use leading dot for subdomains)
SESSION_COOKIE_DOMAIN=.elevenfold.com

# Session secret (use a strong random value in production)
# Generate with: openssl rand -base64 32
SESSION_SECRET=dev-session-secret-change-in-production

# =============================================================================
# React App Configuration
# =============================================================================
# These override the defaults in docker-compose.yml
REACT_APP_API_URL=https://beta.elevenfold.com
REACT_APP_KEYCLOAK_URL=http://localhost:8180
REACT_APP_KEYCLOAK_REALM=11id
REACT_APP_KEYCLOAK_CLIENT_ID=marty-ui
REACT_APP_PUBLIC_URL=https://beta.elevenfold.com
REACT_APP_ENVIRONMENT=tunnel

# =============================================================================
# Keycloak Configuration (Optional - for external access)
# =============================================================================
# Uncomment these if you want Keycloak accessible via Cloudflare Tunnel
# Note: Requires separate tunnel hostname (e.g., auth-beta.elevenfold.com)
#
# KC_HOSTNAME=beta.elevenfold.com
# KC_HOSTNAME_PORT=443
# KC_PROXY=edge
#
# OIDC_ISSUER_URL=https://beta.elevenfold.com/auth/realms/11id
# OIDC_BACKEND_ISSUER_URL=http://keycloak:8080/realms/11id
# OIDC_REDIRECT_URI=https://beta.elevenfold.com/auth/callback
# OIDC_POST_LOGOUT_REDIRECT_URI=https://beta.elevenfold.com

# Keep these as defaults if Keycloak stays local:
OIDC_ISSUER_URL=http://localhost:8180/realms/11id
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000

# =============================================================================
# Keycloak Realm Settings
# =============================================================================
KEYCLOAK_REALM=11id
KEYCLOAK_CLIENT_ID=marty-ui

# =============================================================================
# Development Overrides (Optional)
# =============================================================================
# Override other docker-compose.yml settings as needed
# LOG_LEVEL=INFO
# DEBUG=false
# ADAPTER_MODE=spruceid
# STORAGE_MODE=memory
