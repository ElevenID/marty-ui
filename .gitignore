# =============================================================================
# Environment Variables
# =============================================================================
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Cloudflare Tunnel configuration (contains secrets)
.env.tunnel
.env.tunnel-auth

# Oracle Cloud production secrets (NEVER commit)
.env.production

# Keep example env files tracked
!.env.example
!.env*.example
!.env.production.example

