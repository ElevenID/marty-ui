# =============================================================================
# .env.production — Oracle Cloud production secrets & config
#
# DO NOT commit this file to git (it's in .gitignore).
# Copy from k8s/oracle/02-secrets-template.yaml guidance and fill in.
# Used by scripts/deploy-oracle.sh to create Kubernetes Secrets.
# =============================================================================

# ── OCI / OCIR ──────────────────────────────────────────────────────────────
OCI_REGION=us-ashburn-1
OCIR_TENANCY_NAMESPACE=          # Find in OCI Console → Tenancy Details → Object Storage Namespace
OCI_USERNAME=                    # Your OCI user name (e.g. john.doe@company.com)
OCIR_AUTH_TOKEN=                 # Generate in OCI Console → Identity → Users → Your user → Auth Tokens
OCIR_REGISTRY=                   # Auto-derived if OCI_REGION + OCIR_TENANCY_NAMESPACE are set;
                                 # or set manually: e.g. iad.ocir.io/axmpqrs12345

# ── Image Tag ────────────────────────────────────────────────────────────────
IMAGE_TAG=prod

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=
KEYCLOAK_DB_PASSWORD=

# ── Keycloak admin ──────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=

# ── Keycloak service account ─────────────────────────────────────────────────
MARTY_API_CLIENT_SECRET=         # Must match client secret in Keycloak realm config

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_PASSWORD=
RABBITMQ_ERLANG_COOKIE=          # Random string, e.g.: openssl rand -hex 32

# ── Session security ─────────────────────────────────────────────────────────
SESSION_SECRET_KEY=              # Random 64-char hex, e.g.: openssl rand -hex 32

# ── Google OAuth2 (optional) ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_USERNAME=
SMTP_PASSWORD=

# ── Cloudflare ───────────────────────────────────────────────────────────────
# Paste the full token from: Cloudflare Zero Trust → Networks → Tunnels → Create tunnel
CLOUDFLARE_TUNNEL_TOKEN=
