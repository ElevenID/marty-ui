# =============================================================================
# .env.production — Kubernetes self-host reference deployment settings
#
# DO NOT commit real secrets to git.
# Source this file before running scripts/deploy-oracle.sh, or pass it with
# --env-file. For sensitive values, you can set VAR directly or VAR_FILE to a
# readable file path; the deploy script resolves either form.
# =============================================================================

# ── OCI / OCIR ──────────────────────────────────────────────────────────────
OCI_REGION=us-ashburn-1
OCIR_TENANCY_NAMESPACE=          # OCI Console → Tenancy Details → Object Storage Namespace
OCI_USERNAME=                    # OCI user name used for OCIR auth
OCIR_AUTH_TOKEN=                 # OCI Console → Identity → Users → Auth Tokens
OCIR_REGISTRY=                   # Optional override, e.g. iad.ocir.io/axmpqrs12345

# ── Image Tag ────────────────────────────────────────────────────────────────
# Use an immutable release tag, for example 2026.05.0.
IMAGE_TAG=REPLACE_WITH_RELEASE_TAG

# ── Public hostnames ─────────────────────────────────────────────────────────
PUBLIC_DOMAIN=prod.example.com
PUBLIC_API_URL=https://prod.example.com
UI_BASE_URL=https://prod.example.com
# Optional: set only for a secondary hostname intentionally served by this same stack.
# Do not put a separate beta/staging stack hostname here; it will use this Keycloak issuer.
UI_ADDITIONAL_BASE_URLS=
KC_HOSTNAME=prod.example.com
KEYCLOAK_REALM=11id
OIDC_CLIENT_ID=marty-ui
OIDC_ISSUER_URL_EXTERNAL=https://prod.example.com/realms/11id
OIDC_REDIRECT_URI=https://prod.example.com/v1/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=https://prod.example.com/
CORS_ORIGINS=https://prod.example.com

# ── Runtime settings ─────────────────────────────────────────────────────────
COOKIE_SAMESITE=lax
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
CREDENTIAL_LOGIN_POLICY_ID=50000000-0000-0000-0000-000000000004
KEYCLOAK_TOKEN_EXCHANGE_ENABLED=false
BAO_ADDR=https://vault.example.com
UNIVERSAL_RESOLVER_URL=
MARTY_MIGRATION_PROFILE=production
MARTY_ORG_ID=00000000-0000-0000-0000-000000000001
MARTY_ORG_ADMIN_EMAIL=
KEYCLOAK_REMOVE_DEMO_USERS=true
MARTY_LICENSE_ENFORCEMENT=required
MARTY_LICENSE_REQUIRED_ISSUER=marty-license-issuer
MARTY_LICENSE_REQUIRED_PLAN_TIER=system
MARTY_LICENSE_REQUIRED_PRODUCTS=ui-app
RATE_LIMIT_RPM=300
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=
SQUARE_PLAN_STARTER_ID=
SQUARE_PLAN_PROFESSIONAL_ID=
SQUARE_PLAN_ENTERPRISE_ID=
KEYCLOAK_REPLACE_UI_ORIGINS=true

# Canvas Credentials institutional mirror.
# Keep provider=bridge for sandbox receivers. Set provider=badgr_api to publish to the real Canvas Credentials API.
# Real Canvas Credentials API tokens are stored by organization admins in the Canvas integration wizard.
CANVAS_CREDENTIALS_PROVIDER=bridge
CANVAS_CREDENTIALS_API_BASE_URL=https://api.badgr.io
CANVAS_CREDENTIALS_API_ORIGIN_ALLOWLIST=
CANVAS_CREDENTIALS_ISSUER_ID=
CANVAS_CREDENTIALS_BADGECLASS_ID=
CANVAS_CREDENTIALS_ASSERTION_SCOPE=badgeclasses
CANVAS_CREDENTIALS_PROVENANCE_BASE_URL=https://prod.example.com
CANVAS_CREDENTIALS_RECIPIENT_HASHED=true
CANVAS_CREDENTIALS_ALLOW_DUPLICATE_AWARDS=false
CANVAS_LTI_EXPERIENCE_BASE_URL=https://prod.example.com
CANVAS_LTI_TOOL_SIGNING_ORGANIZATION_ID=
CANVAS_LTI_TOOL_SIGNING_SERVICE_ID=
CANVAS_LTI_TOOL_SIGNING_KEY_REFERENCE=
# Required when portable Canvas is enabled: comma-separated credential issuer/document signer key references.
CANVAS_CREDENTIAL_ISSUER_KEY_REFERENCES=
CANVAS_LTI_TOOL_ACTIVE_KID=
# Compact public RSA JWKS JSON only; private JWK parameters are rejected by preflight.
CANVAS_LTI_TOOL_PUBLIC_JWKS=
CANVAS_PORTABLE_INTEGRATION_ENABLED=false
CANVAS_PILOT_ORGANIZATION_IDS=
CANVAS_LEGACY_EVENT_INGEST_ENABLED=false
CANVAS_PRIVATE_ORIGIN_ALLOWLIST=
CANVAS_SELF_MANAGED_ORIGIN_ALLOWLIST=
CANVAS_BINDING_READINESS_MAX_AGE_SECONDS=900
CANVAS_ISSUANCE_EVIDENCE_MAX_AGE_SECONDS=900
CANVAS_BACKGROUND_ROSTER_BATCH_SIZE=500
CANVAS_BACKGROUND_ROSTER_MAX_SIZE=5000
CANVAS_SYNC_PROCESSOR=issuance.infrastructure.api.canvas_routes:process_authoritative_canvas_sync_target
CANVAS_SYNC_WORKER_BATCH_SIZE=10
CANVAS_SYNC_WORKER_LEASE_SECONDS=120
CANVAS_SYNC_WORKER_JOB_TIMEOUT_SECONDS=600
CANVAS_SYNC_SCHEDULE_LIMIT=100
CANVAS_OAUTH_REVOCATION_BATCH_SIZE=25
CANVAS_SYNC_WORKER_POLL_SECONDS=5
CANVAS_ALLOW_PRIVATE_BASE_URLS=false
CANVAS_ALLOW_HTTP_LOCALHOST_BASE_URLS=false

# ── Sensitive inputs (VAR or VAR_FILE) ───────────────────────────────────────
POSTGRES_PASSWORD=
KEYCLOAK_DB_PASSWORD=
MARTY_DB_PASSWORD=
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=
MARTY_API_CLIENT_SECRET=
RABBITMQ_PASSWORD=
RABBITMQ_ERLANG_COOKIE=
SESSION_SECRET_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SMTP_USERNAME=
SMTP_PASSWORD=
ISSUANCE_API_KEY=
TOKEN_HMAC_KEY=
INTEGRATION_SECRET_MASTER_KEY=
OPENBAO_SERVICE_TOKEN=
CANVAS_CREDENTIALS_SHARED_SECRET=
LICENSE_KEY=
SQUARE_ACCESS_TOKEN=
SQUARE_WEBHOOK_SIGNATURE_KEY=
CLOUDFLARE_TUNNEL_TOKEN=
