{
  "schema_version": 1,
  "name": "kubernetes-production",
  "description": "Provider-neutral Kubernetes production deployment using signed public Marty images.",
  "env_file": ".env.production",
  "manifest_dir": "k8s/oracle",
  "namespace": "marty-prod",
  "domains": ["elevenidllc.com"],
  "primary_domain": "elevenidllc.com",
  "required_service_groups": ["app"],
  "required_services": ["canvas-sync-worker", "ui", "cloudflared"],
  "required_secrets": [
    "postgres_password",
    "keycloak_db_password",
    "marty_db_password",
    "keycloak_admin_password",
    "marty_api_client_secret",
    "rabbitmq_password",
    "rabbitmq_erlang_cookie",
    "session_secret_key",
    "issuance_api_key",
    "integration_secret_master_key",
    "openbao_service_token"
  ],
  "artifact_profile": "oss-release",
  "deployment_targets": ["kubernetes"],
  "operations": {
    "status": ["status"],
    "setup-secrets": ["setup-secrets"],
    "update-images": ["update-images"],
    "deploy": ["deploy"]
  }
}
