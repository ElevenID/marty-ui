{
  "schema_version": 1,
  "name": "tunnel-beta-experiments",
  "description": "Reset-friendly beta.elevenidllc.com experiments stack with real Canvas LMS enabled for production-like Canvas/LTI demos.",
  "parent_stack": "tunnel-beta-dev",
  "env_file": ".env.tunnel.beta.local",
  "compose_files": [
    "docker-compose.base.yml",
    "docker-compose.profile.dev.yml",
    "docker-compose.profile.tunnel.yml",
    "docker-compose.profile.canvas-real.yml",
    "docker-compose.profile.canvas-sandbox.yml"
  ],
  "compose_profiles": [],
  "domains": ["beta.elevenidllc.com", "canvas-test.elevenidllc.com", "canvas-sandbox.elevenidllc.com"],
  "primary_domain": "beta.elevenidllc.com",
  "required_service_groups": ["infra", "app", "canvas_experiments"],
  "required_services": ["tunnel-nginx-proxy", "cloudflared"],
  "required_secrets": ["cloudflare_tunnel_token", "canvas_credentials_shared_secret"],
  "license_policy": "internal-dev",
  "artifact_profile": "source-debuggable",
  "deployment_targets": ["docker-compose"],
  "experiments": {
    "migration_profile": "experiments",
    "canvas": {
      "enabled": true,
      "public_host": "canvas-test.elevenidllc.com",
      "credentials_mirror_host": "canvas-sandbox.elevenidllc.com",
      "organization_id": "00000000-0000-0000-0000-000000000001",
      "credential_template_id": "50000000-0000-0000-0000-000000000041",
      "application_template_id": "0ab66d45-0d84-5fbd-837f-25788d3227a1"
    }
  },
  "operations": {
    "config": ["config"],
    "up": ["up", "-d"],
    "down": ["down"],
    "ps": ["ps"],
    "logs": ["logs", "-f"]
  }
}
