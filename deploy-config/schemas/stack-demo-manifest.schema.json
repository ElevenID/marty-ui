{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elevenidllc.com/schemas/stack-demo-manifest.schema.json",
  "title": "ElevenID LLC Credential Platform Demo Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "stack_version",
    "release_name",
    "mip_version",
    "publication_state",
    "coverage_state",
    "release_ready",
    "public_demo_ready",
    "published_at",
    "publication_approval",
    "video_distribution",
    "deployment_release_marker",
    "recorder_revision",
    "component_revisions",
    "image_digests",
    "release_evidence",
    "release_differences",
    "scenarios"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "stack_version": { "type": "string", "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]+$" },
    "release_name": { "type": "string", "minLength": 3, "maxLength": 80 },
    "mip_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "publication_state": { "enum": ["DRAFT", "PUBLIC", "SUPERSEDED"] },
    "coverage_state": { "enum": ["PARTIAL", "COMPLETE", "SUPERSEDED"] },
    "release_ready": { "type": "boolean" },
    "public_demo_ready": { "type": "boolean" },
    "video_distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "status",
        "channel_name",
        "channel_id",
        "channel_handle",
        "channel_url",
        "playlist_id",
        "playlist_url",
        "privacy_enhanced_embeds",
        "verified_at"
      ],
      "properties": {
        "provider": { "const": "YOUTUBE" },
        "status": { "enum": ["PENDING_CHANNEL_SETUP", "CONFIGURED"] },
        "channel_name": { "const": "ElevenID LLC" },
        "channel_id": { "type": ["string", "null"], "pattern": "^UC[A-Za-z0-9_-]{22}$" },
        "channel_handle": { "type": ["string", "null"], "pattern": "^@[A-Za-z0-9._-]{3,30}$" },
        "channel_url": { "type": ["string", "null"], "format": "uri" },
        "playlist_id": { "type": ["string", "null"], "pattern": "^[A-Za-z0-9_-]{10,64}$" },
        "playlist_url": { "type": ["string", "null"], "format": "uri" },
        "privacy_enhanced_embeds": { "const": true },
        "verified_at": { "type": ["string", "null"], "format": "date-time" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "CONFIGURED" } } },
          "then": {
            "properties": {
              "channel_id": { "type": "string", "pattern": "^UC[A-Za-z0-9_-]{22}$" },
              "channel_url": { "type": "string", "format": "uri" },
              "playlist_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{10,64}$" },
              "playlist_url": { "type": "string", "format": "uri" },
              "verified_at": { "type": "string", "format": "date-time" }
            }
          }
        }
      ]
    },
    "deployment_release_marker": { "type": "string", "minLength": 1 },
    "published_at": { "type": ["string", "null"], "format": "date-time" },
    "publication_approval": { "$ref": "#/$defs/publicationApproval" },
    "superseded_by": { "type": ["string", "null"], "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]+$" },
    "recorder_revision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": { "enum": ["git", "unversioned-source-snapshot"] },
        "value": { "type": "string", "minLength": 12 }
      }
    },
    "component_revisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component", "repository", "revision"],
        "properties": {
          "component": { "type": "string", "minLength": 1 },
          "repository": { "type": "string", "format": "uri" },
          "revision": { "type": "string", "pattern": "^[a-f0-9]{40}$" }
        }
      }
    },
    "image_digests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component", "digest"],
        "properties": {
          "component": { "type": "string", "minLength": 1 },
          "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
        }
      }
    },
    "release_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environment", "recorded_at", "displayed_offers_invalidated_at", "source_marker", "artifacts"],
      "properties": {
        "environment": { "type": "string", "minLength": 1 },
        "recorded_at": { "type": "string", "format": "date-time" },
        "displayed_offers_invalidated_at": { "type": "string", "format": "date-time" },
        "source_marker": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "sha256", "visibility"],
            "properties": {
              "label": { "type": "string", "minLength": 1 },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "visibility": { "enum": ["PROTECTED", "PUBLIC"] }
            }
          }
        }
      }
    },
    "release_differences": {
      "type": "object",
      "additionalProperties": false,
      "required": ["previous_stack_version", "ux", "services", "wallets", "integrations", "operations"],
      "properties": {
        "previous_stack_version": { "type": ["string", "null"] },
        "ux": { "$ref": "#/$defs/stringList" },
        "services": { "$ref": "#/$defs/stringList" },
        "wallets": { "$ref": "#/$defs/stringList" },
        "integrations": { "$ref": "#/$defs/stringList" },
        "operations": { "$ref": "#/$defs/stringList" }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scenario" }
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slug",
        "title",
        "summary",
        "scenario_revision",
        "mip_version",
        "state",
        "audiences",
        "capabilities",
        "protocols",
        "poster",
        "youtube_id",
        "media_evidence",
        "transcript",
        "chapters",
        "wallets",
        "assertions",
        "limitations",
        "published_at",
        "publication_approval",
        "inherited_evidence"
      ],
      "properties": {
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "scenario_revision": { "type": "integer", "minimum": 1 },
        "mip_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "state": { "enum": ["DRAFT", "VALIDATED", "YOUTUBE_UNLISTED", "PUBLIC", "SUPERSEDED"] },
        "audiences": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["Holder", "Issuer", "Verifier", "Administrator", "Developer"] }
        },
        "capabilities": { "$ref": "#/$defs/stringList" },
        "protocols": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "poster": {
          "type": "object",
          "additionalProperties": false,
          "required": ["src", "sha256", "alt"],
          "properties": {
            "src": { "type": "string", "pattern": "^/images/demos/" },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "alt": { "type": "string", "minLength": 1 }
          }
        },
        "youtube_id": { "type": ["string", "null"], "pattern": "^[A-Za-z0-9_-]{11}$" },
        "media_evidence": { "$ref": "#/$defs/mediaEvidence" },
        "transcript": {
          "type": "object",
          "additionalProperties": false,
          "required": ["language", "segments"],
          "properties": {
            "language": { "const": "en" },
            "segments": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["start_seconds", "speaker", "text"],
                "properties": {
                  "start_seconds": { "type": "integer", "minimum": 0 },
                  "speaker": { "type": "string", "minLength": 1 },
                  "text": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        },
        "chapters": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["start_seconds", "title", "role", "mip_primitives", "standards", "documentation_links"],
            "properties": {
              "start_seconds": { "type": "integer", "minimum": 0 },
              "title": { "type": "string", "minLength": 1 },
              "role": { "enum": ["Holder", "Issuer", "Verifier", "Administrator", "Developer"] },
              "mip_primitives": { "$ref": "#/$defs/stringList" },
              "standards": { "$ref": "#/$defs/stringList" },
              "documentation_links": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["label", "href"],
                  "properties": {
                    "label": { "type": "string", "minLength": 1 },
                    "href": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          }
        },
        "wallets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["implementation", "vendor", "build", "deployment_mode", "classification", "protocols", "capabilities", "result", "tested_at"],
            "properties": {
              "implementation": { "type": "string", "minLength": 1 },
              "vendor": { "type": "string", "minLength": 1 },
              "build": { "type": "string", "minLength": 1 },
              "image_digest": { "type": ["string", "null"], "pattern": "^sha256:[a-f0-9]{64}$" },
              "apk_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
              "deployment_mode": { "enum": ["BROWSER", "SELF_HOSTED_BROWSER", "ANDROID_EMULATOR", "PHYSICAL_DEVICE", "INTERNAL_CONTROL"] },
              "classification": { "enum": ["FIRST_PARTY", "INDEPENDENT", "INTERNAL_CONTROL"] },
              "protocols": { "$ref": "#/$defs/stringList" },
              "capabilities": { "$ref": "#/$defs/stringList" },
              "result": { "enum": ["PASS", "FAIL", "BLOCKED", "NOT_RUN"] },
              "tested_at": { "type": ["string", "null"], "format": "date-time" }
            }
          }
        },
        "assertions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "label", "result", "evidence_sha256"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
              "label": { "type": "string", "minLength": 1 },
              "result": { "enum": ["PASS", "FAIL", "BLOCKED", "NOT_RUN"] },
              "evidence_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }
            }
          }
        },
        "limitations": { "$ref": "#/$defs/stringList" },
        "published_at": { "type": ["string", "null"], "format": "date-time" },
        "publication_approval": { "$ref": "#/$defs/publicationApproval" },
        "inherited_evidence": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["source_stack_version", "source_scenario_revision", "attested_at", "attestation_sha256", "byte_identical_components", "unchanged_protocols", "unchanged_wallets", "unchanged_behavior"],
          "properties": {
            "source_stack_version": { "type": "string", "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]+$" },
            "source_scenario_revision": { "type": "integer", "minimum": 1 },
            "attested_at": { "type": "string", "format": "date-time" },
            "attestation_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "byte_identical_components": { "const": true },
            "unchanged_protocols": { "const": true },
            "unchanged_wallets": { "const": true },
            "unchanged_behavior": { "const": true }
          }
        }
      }
    },
    "mediaEvidence": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "video_sha256",
            "captions_sha256",
            "thumbnail_sha256",
            "privacy_scan_sha256",
            "publication_config_sha256",
            "youtube_uploaded_at"
          ],
          "properties": {
            "video_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "captions_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "thumbnail_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "privacy_scan_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "publication_config_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "youtube_uploaded_at": { "type": "string", "format": "date-time" }
          }
        }
      ]
    },
    "publicationApproval": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["approval_sha256", "reviewed_at", "checks"],
          "properties": {
            "approval_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "reviewed_at": { "type": "string", "format": "date-time" },
            "checks": {
              "type": "array",
              "minItems": 8,
              "maxItems": 8,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "accessibility",
                  "canonical-urls",
                  "captions",
                  "evidence",
                  "links",
                  "metadata",
                  "navigation",
                  "playback",
                  "privacy",
                  "responsive-layouts",
                  "thumbnail",
                  "transcript",
                  "version-selection"
                ]
              }
            }
          }
        }
      ]
    }
  }
}
