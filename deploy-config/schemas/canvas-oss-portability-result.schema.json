{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elevenidllc.com/schemas/canvas-oss-portability-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "suite", "status", "run", "canvas", "marty", "driver", "attestation", "cases"],
  "properties": {
    "schema_version": {"const": 1},
    "suite": {"const": "canvas_oss_portability"},
    "status": {"enum": ["passed", "failed", "readiness_only"]},
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["started_at", "finished_at", "mode"],
      "properties": {
        "started_at": {"type": "string", "format": "date-time"},
        "finished_at": {"type": "string", "format": "date-time"},
        "mode": {"enum": ["full", "readiness_only"]}
      }
    },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_tag", "source_tag_object", "source_commit", "source_tree", "release_train", "image_digest", "base_image", "origin", "runtime_dependencies"],
      "properties": {
        "source_tag": {"const": "release/2026-05-06.409"},
        "source_tag_object": {"const": "116bf6129f2658f0c292f6242f966b19c1117309"},
        "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "source_tree": {"const": "63f3a4528a7daaccc057eb4e2acac93af89d3c92"},
        "release_train": {"const": "stable/2026-05-06"},
        "image_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "base_image": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reference", "index_digest", "linux_amd64_digest"],
          "properties": {
            "reference": {"const": "instructure/ruby-passenger:3.4-jammy"},
            "index_digest": {"const": "sha256:80d3a0e22c6ae228494de406d67fca88d7ff2de89fece021423206087190fcbe"},
            "linux_amd64_digest": {"const": "sha256:f928f286e0ea1cbef59025251dbfd121ae748dc4f94a54c85240e842d459e776"}
          }
        },
        "origin": {"const": "https://canvas-test.elevenidllc.com"},
        "runtime_dependencies": {
          "type": "object",
          "additionalProperties": false,
          "required": ["postgres", "redis", "mailpit", "edge"],
          "properties": {
            "postgres": {"type": "string", "pattern": "@sha256:[0-9a-f]{64}$"},
            "redis": {"type": "string", "pattern": "@sha256:[0-9a-f]{64}$"},
            "mailpit": {"type": "string", "pattern": "@sha256:[0-9a-f]{64}$"},
            "edge": {"type": "string", "pattern": "@sha256:[0-9a-f]{64}$"}
          }
        }
      }
    },
    "marty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin", "release_version", "source_id"],
      "properties": {
        "origin": {"const": "https://beta.elevenidllc.com"},
        "release_version": {"type": "string", "minLength": 1},
        "source_id": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
      }
    },
    "driver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "execution_boundary", "compose_service", "image_id", "source_sha", "base_image", "secret_transport", "host_browser_processes"],
      "properties": {
        "status": {"enum": ["executed", "not_run"]},
        "execution_boundary": {"const": "docker_compose_one_shot"},
        "compose_service": {"const": "canvas-contract"},
        "image_id": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"},
        "source_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
        "base_image": {"type": "string", "pattern": "^mcr\\.microsoft\\.com/playwright:v1\\.56\\.0-jammy@sha256:[0-9a-f]{64}$"},
        "secret_transport": {"const": "compose_secret_files"},
        "host_browser_processes": {"const": false}
      }
    },
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canvas_source_modified", "canvas_custom_plugins", "rails_runner_calls", "rails_console_calls", "post_bootstrap_database_access", "legacy_event_ingest", "new_quizzes", "canvas_credentials"],
      "properties": {
        "canvas_source_modified": {"const": false},
        "canvas_custom_plugins": {"type": "array", "maxItems": 0},
        "rails_runner_calls": {"const": 0},
        "rails_console_calls": {"const": 0},
        "post_bootstrap_database_access": {"const": false},
        "legacy_event_ingest": {"const": false},
        "new_quizzes": {"const": "hosted_required"},
        "canvas_credentials": {"const": "outside_gate"}
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "classification", "status", "evidence"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "classification": {"enum": ["oss_required", "hosted_required", "outside_gate"]},
          "status": {"enum": ["passed", "failed", "hosted_required", "outside_gate", "not_run"]},
          "evidence": {"type": "string", "maxLength": 240}
        }
      }
    }
  }
}
