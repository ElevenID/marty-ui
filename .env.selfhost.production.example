# Copy to .env.selfhost.production.local.
# Put real secrets in SELFHOST_SECRET_DIR instead of this env file.

SELFHOST_SECRET_DIR=/path/to/selfhost-secrets
SELFHOST_STATE_DIR=/path/to/selfhost-state
SELFHOST_BACKUP_DIR=../marty-selfhost-prod/backups
SELFHOST_OPENBAO_STATE_DIR=../marty-selfhost-prod/openbao/state
SELFHOST_OPENBAO_EXPORT_DIR=../marty-selfhost-prod/openbao/exports
SELFHOST_OPENBAO_HOST_PORT=18200
SELFHOST_IMAGE_PREFIX=ghcr.io/elevenid/marty-ui
# Use an immutable release tag in production, for example 2026.05.0.
SELFHOST_IMAGE_TAG=REPLACE_WITH_RELEASE_TAG

PUBLIC_DOMAIN=prod.example.com
PUBLIC_API_URL=https://prod.example.com
UI_BASE_URL=https://prod.example.com
# Optional: set only for a secondary hostname intentionally served by this same stack.
# Do not put a separate beta/staging stack hostname here; it will use this Keycloak issuer.
UI_ADDITIONAL_BASE_URLS=
BAO_ADDR=http://host.docker.internal:18200
GRPC_INSECURE_ALLOWED=true
KEYCLOAK_REALM=11id
OIDC_ISSUER_URL_EXTERNAL=https://prod.example.com/realms/11id
OIDC_REDIRECT_URI=https://prod.example.com/v1/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=https://prod.example.com/
CORS_ORIGINS=https://prod.example.com

MARTY_MIGRATION_PROFILE=selfhost-production
MARTY_ORG_ID=00000000-0000-0000-0000-000000000001
MARTY_ORG_DOMAIN=prod.example.com
MARTY_ORG_ADMIN_EMAIL=
ORGANIZATION_CREATION_ENABLED=false
KEYCLOAK_REMOVE_DEMO_USERS=true
MARTY_LICENSE_ENFORCEMENT=required
MARTY_LICENSE_REQUIRED_ISSUER=marty-license-issuer
MARTY_LICENSE_REQUIRED_PLAN_TIER=system
MARTY_LICENSE_REQUIRED_PRODUCTS=ui-app

KEYCLOAK_ADMIN=admin
KEYCLOAK_REPLACE_UI_ORIGINS=true
KEYCLOAK_USER_REGISTRATION_ENABLED=true
KEYCLOAK_VERIFY_EMAIL=true
KEYCLOAK_RESET_PASSWORD_ENABLED=true
KEYCLOAK_SOCIAL_LOGIN_ENABLED=false
KEYCLOAK_ORGANIZATION_IDENTITY_FIRST_ENABLED=false
CREDENTIAL_LOGIN_POLICY_ID=50000000-0000-0000-0000-000000000004
KEYCLOAK_SMTP_HOST=smtp.example.com
KEYCLOAK_SMTP_PORT=587
KEYCLOAK_SMTP_FROM=noreply@prod.example.com
KEYCLOAK_SMTP_FROM_DISPLAY_NAME=Marty Trust Services
KEYCLOAK_SMTP_USERNAME=
KEYCLOAK_SMTP_SSL=false
KEYCLOAK_SMTP_STARTTLS=true
CREDENTIAL_LOGIN_REQUIRE_EXISTING_KEYCLOAK_USER=true
CREDENTIAL_LOGIN_CREATE_USERS=false
# Google login, GA4, and Search Console values now live in SELFHOST_SECRET_DIR:
# - google_client_id
# - google_client_secret
# - google_analytics_measurement_id
# - google_site_verification
SMTP_USERNAME=

SELFHOST_EDGE_HOST_PORT=19080
SELFHOST_GATEWAY_HOST_PORT=18000
SELFHOST_KEYCLOAK_HOST_PORT=18180

RATE_LIMIT_RPM=300
COOKIE_SAMESITE=lax
UNIVERSAL_RESOLVER_URL=

# Canvas Credentials institutional mirror.
# Keep provider=bridge for sandbox receivers. Set provider=badgr_api to publish to the real Canvas Credentials API.
CANVAS_CREDENTIALS_PROVIDER=bridge
CANVAS_CREDENTIALS_API_BASE_URL=https://api.badgr.io
CANVAS_CREDENTIALS_ISSUER_ID=
CANVAS_CREDENTIALS_BADGECLASS_ID=
CANVAS_CREDENTIALS_ASSERTION_SCOPE=badgeclasses
CANVAS_CREDENTIALS_PROVENANCE_BASE_URL=https://prod.example.com
CANVAS_CREDENTIALS_RECIPIENT_HASHED=true
CANVAS_CREDENTIALS_ALLOW_DUPLICATE_AWARDS=false

SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=
SQUARE_PLAN_STARTER_ID=
SQUARE_PLAN_PROFESSIONAL_ID=
SQUARE_PLAN_ENTERPRISE_ID=
