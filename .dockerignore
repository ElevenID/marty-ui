# NOTE: This file applies when building from marty-ui/ as the build context.
# For the microservices (docker-compose.base.yml), the build context is the
# parent directory (work/), so the effective .dockerignore is work/.dockerignore.
#
# Node modules - will be installed fresh in container
**/node_modules
**/npm-debug.log

# Build outputs
**/build
**/dist
**/.next
**/out

# Python cache
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache
**/.coverage
**/.mypy_cache

# Git
.git
.gitignore

# IDE
.vscode
.idea
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Test results
**/test-results
**/playwright-report
**/coverage

# Environment
.env
.env.local
.env.*.local

# Documentation
*.md
!README.md

# Logs
*.log
