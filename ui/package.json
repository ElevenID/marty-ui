{
  "name": "marty-ui",
  "version": "1.1.0",
  "description": "OpenWallet Foundation mDoc/mDL Demo UI with Enhanced Features",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-demo-manifest-module.mjs && node -e \"require('fs').mkdirSync('dist', { recursive: true })\"",
    "build": "tsc -p tsconfig.build.json && vite build",
    "analyze:bundle": "tsc -p tsconfig.build.json && vite build --mode analyze",
    "build:selfhost": "node scripts/build-selfhost.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:prerendered-seo": "npm run build && vitest run src/__tests__/prerenderedSeo.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "cross-env DISABLE_PRERENDER=1 storybook build",
    "test:visual": "playwright test tests/visual",
    "check:demo-manifests": "node scripts/generate-demo-manifest-module.mjs --check",
    "postinstall": "node scripts/patch-prerenderer-ts-deepmerge.cjs"
  },
  "dependencies": {
    "@elevenid/marty-api-core": "https://github.com/ElevenID/marty-cli/releases/download/v0.1.0/elevenid-marty-api-core-0.1.0.tgz",
    "@elevenid/marty-blog": "https://github.com/ElevenID/marty-blog/releases/download/v0.1.3/elevenid-marty-blog-0.1.3.tgz",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@mui/x-date-pickers": "^9.10.0",
    "axios": "^1.18.1",
    "date-fns": "^4.4.0",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "node-forge": "^1.4.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.10",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "redoc": "^2.5.3",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@prerenderer/renderer-puppeteer": "^1.2.4",
    "@prerenderer/rollup-plugin": "^0.3.12",
    "@storybook/react": "^10.5.2",
    "@storybook/react-vite": "^10.5.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "ajv": "^8.20.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "msw-storybook-addon": "^2.0.7",
    "puppeteer": "^25.3.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^10.5.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-checker": "^0.14.4",
    "vite-plugin-sitemap": "^0.8.2",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "ts-deepmerge": "8.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
