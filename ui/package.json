{
  "name": "marty-ui",
  "version": "1.0.0",
  "description": "OpenWallet Foundation mDoc/mDL Demo UI with Enhanced Features",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-demo-manifest-module.mjs && node -e \"require('fs').mkdirSync('dist', { recursive: true })\"",
    "build": "tsc -p tsconfig.build.json && vite build",
    "analyze:bundle": "tsc -p tsconfig.build.json && vite build --mode analyze",
    "build:selfhost": "node scripts/build-selfhost.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:prerendered-seo": "npm run build && vitest run src/__tests__/prerenderedSeo.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test:visual": "playwright test tests/visual",
    "check:demo-manifests": "node scripts/generate-demo-manifest-module.mjs --check"
  },
  "dependencies": {
    "@elevenid/marty-api-core": "file:../../marty-cli/packages/api-core",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@marty/blog": "file:../../marty-blog",
    "@marty/subscriptions": "file:../../marty-subscriptions",
    "@mui/icons-material": "^5.14.0",
    "@mui/material": "^5.14.0",
    "@mui/x-date-pickers": "^6.18.0",
    "axios": "^1.6.0",
    "date-fns": "^2.30.0",
    "i18next": "^23.7.0",
    "i18next-browser-languagedetector": "^7.2.0",
    "i18next-http-backend": "^2.4.0",
    "node-forge": "^1.3.1",
    "qrcode.react": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.4",
    "react-i18next": "^14.0.0",
    "react-qr-scanner": "^1.0.0-alpha.11",
    "react-router-dom": "^6.8.0",
    "recharts": "^2.10.3",
    "redoc": "^2.1.5",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@prerenderer/renderer-puppeteer": "^1.2.4",
    "@prerenderer/rollup-plugin": "^0.3.12",
    "@storybook/addon-essentials": "^7.6.0",
    "@storybook/addon-interactions": "^7.6.0",
    "@storybook/addon-links": "^7.6.0",
    "@storybook/blocks": "^7.6.0",
    "@storybook/react": "^7.6.0",
    "@storybook/react-vite": "^7.6.0",
    "@storybook/test": "^7.6.0",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/minimatch": "^5.1.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.3.0",
    "@vitest/ui": "^1.3.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^24.0.0",
    "msw": "^2.1.0",
    "msw-storybook-addon": "^2.0.0",
    "puppeteer": "^22.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^7.6.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-checker": "^0.6.4",
    "vite-plugin-sitemap": "^0.7.1",
    "vitest": "^1.3.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
