# API Configuration
VITE_API_URL=http://localhost:8000
VITE_OPENAPI_URL=/openapi.json

# Keycloak Configuration
VITE_KEYCLOAK_REALM=marty
VITE_KEYCLOAK_CLIENT_ID=marty-frontend

# Google Analytics (GA4)
# Get your Measurement ID from https://analytics.google.com/
# Format: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# Environment
VITE_ENVIRONMENT=development

# Admin impersonation feature flag
# Defaults to enabled in non-production and disabled in production when unset.
# Set explicitly to true/false per environment if needed.
VITE_ENABLE_ADMIN_IMPERSONATION=true
