# Frontend Environment Variables (Vite)
# Copy this file to .env and customize values for your environment

# =============================================================================
# API Configuration
# =============================================================================
# API URL for backend services (used for API calls and dev proxy)
# In development: This configures the Vite dev server proxy
# In production: Leave empty to use relative paths (same origin)
VITE_API_URL=

# Optional: Additional service URLs if using separate microservices
# These override the default API_URL for specific service endpoints
# VITE_ISSUER_API=http://localhost:8080
# VITE_VERIFIER_API=http://localhost:8081
# VITE_WALLET_API=http://localhost:8082

# =============================================================================
# Mock Service Configuration (Only for isolated UI development without backend)
# =============================================================================
# WARNING: These should NOT be enabled in normal development or production
# Only use when developing UI features in isolation without backend services

# Mock payment provider (bypasses real Square/Stripe integration)
# VITE_USE_MOCK_PAYMENTS=true

# Note: Trust services and other APIs use real backend by default
# Configure backend URL with VITE_API_URL instead of mocking
