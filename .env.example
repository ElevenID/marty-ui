# Demo OpenWallet SDK Environment Configuration
# Copy this file to .env and customize values for your environment

# =============================================================================
# Keycloak Admin Configuration
# =============================================================================
# Admin console credentials (for Keycloak management)
KEYCLOAK_ADMIN_PASSWORD=admin

# Keycloak database password
KEYCLOAK_DB_PASSWORD=keycloak

# =============================================================================
# OIDC Client Configuration
# =============================================================================
OIDC_CLIENT_ID=marty-ui

# =============================================================================
# Demo Administrator User
# =============================================================================
DEMO_ADMIN_EMAIL=admin@marty.demo
DEMO_ADMIN_FIRST_NAME=Admin
DEMO_ADMIN_LAST_NAME=User
DEMO_ADMIN_PASSWORD=Admin123!

# =============================================================================
# Demo Applicant Users
# =============================================================================
# Shared password for all demo applicants
DEMO_APPLICANT_PASSWORD=Applicant123!

# Applicant 1
DEMO_APPLICANT1_EMAIL=john.doe@marty.demo
DEMO_APPLICANT1_FIRST_NAME=John
DEMO_APPLICANT1_LAST_NAME=Doe
DEMO_APPLICANT1_NATIONALITY=USA
DEMO_APPLICANT1_DOB=1985-03-15

# Applicant 2
DEMO_APPLICANT2_EMAIL=jane.smith@marty.demo
DEMO_APPLICANT2_FIRST_NAME=Jane
DEMO_APPLICANT2_LAST_NAME=Smith
DEMO_APPLICANT2_NATIONALITY=GBR
DEMO_APPLICANT2_DOB=1990-07-22

# Applicant 3
DEMO_APPLICANT3_EMAIL=carlos.garcia@marty.demo
DEMO_APPLICANT3_FIRST_NAME=Carlos
DEMO_APPLICANT3_LAST_NAME=Garcia
DEMO_APPLICANT3_NATIONALITY=ESP
DEMO_APPLICANT3_DOB=1978-11-08

# =============================================================================
# Database Configuration
# =============================================================================
# Applicant service database
APPLICANT_DB_PASSWORD=marty

# =============================================================================
# Session & Security
# =============================================================================
# Session cookie max age in seconds (default: 30 minutes)
SESSION_MAX_AGE=1800

# Environment: development or production
# Production enables strict cookie security (Secure, SameSite=Strict, __Host- prefix)
ENVIRONMENT=development
