# Demo OpenWallet SDK Environment Configuration
# Copy this file to .env and customize values for your environment

# =============================================================================
# Keycloak Admin Configuration
# =============================================================================
# Admin console credentials (for Keycloak management)
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=11id

# =============================================================================
# Google OAuth2 (Social Login)
# =============================================================================
# Create credentials at https://console.cloud.google.com/
# Authorized redirect URI: https://<PUBLIC_DOMAIN>/realms/11id/broker/google/endpoint
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# Keycloak Service Account
# =============================================================================
# Secret for the marty-api confidential client (used for token exchange)
MARTY_API_CLIENT_SECRET=marty-api-secret-change-in-production

# =============================================================================
# Credential Login (OID4VP)
# =============================================================================
# UUID of the MemberLogin presentation policy.
# Available policies (seeded by migrations):
#   50000000-...-000000000001  ElevenID org — SD-JWT MemberCredential
#   50000000-...-000000000002  Marty org   — SD-JWT Member Login Credential
#   50000000-...-000000000003  Marty org   — mDoc Membership ID
CREDENTIAL_LOGIN_POLICY_ID=50000000-0000-0000-0000-000000000002
# Internal URL the flow service uses to call back after VP verification
AUTH_SERVICE_INTERNAL_URL=http://auth:8001

# Keycloak database password
KEYCLOAK_DB_PASSWORD=keycloak

# =============================================================================
# OIDC Client Configuration
# =============================================================================
OIDC_CLIENT_ID=marty-ui

# =============================================================================
# Demo Administrator User
# =============================================================================
DEMO_ADMIN_EMAIL=admin@marty.demo
DEMO_ADMIN_FIRST_NAME=Admin
DEMO_ADMIN_LAST_NAME=User
DEMO_ADMIN_PASSWORD=Admin123!

# =============================================================================
# Demo Applicant Users
# =============================================================================
# Shared password for all demo applicants
DEMO_APPLICANT_PASSWORD=Applicant123!

# Applicant 1
DEMO_APPLICANT1_EMAIL=john.doe@marty.demo
DEMO_APPLICANT1_FIRST_NAME=John
DEMO_APPLICANT1_LAST_NAME=Doe
DEMO_APPLICANT1_NATIONALITY=USA
DEMO_APPLICANT1_DOB=1985-03-15

# Applicant 2
DEMO_APPLICANT2_EMAIL=jane.smith@marty.demo
DEMO_APPLICANT2_FIRST_NAME=Jane
DEMO_APPLICANT2_LAST_NAME=Smith
DEMO_APPLICANT2_NATIONALITY=GBR
DEMO_APPLICANT2_DOB=1990-07-22

# Applicant 3
DEMO_APPLICANT3_EMAIL=carlos.garcia@marty.demo
DEMO_APPLICANT3_FIRST_NAME=Carlos
DEMO_APPLICANT3_LAST_NAME=Garcia
DEMO_APPLICANT3_NATIONALITY=ESP
DEMO_APPLICANT3_DOB=1978-11-08

# =============================================================================
# Database Configuration
# =============================================================================
# Applicant service database
APPLICANT_DB_PASSWORD=marty

# =============================================================================
# Session & Security
# =============================================================================
# Session cookie max age in seconds (default: 30 minutes)
SESSION_MAX_AGE=1800

# Environment: development or production
# Production enables strict cookie security (Secure, SameSite=Strict, __Host- prefix)
ENVIRONMENT=development

# =============================================================================
# Frontend Environment Variables (Vite)
# =============================================================================
# API URL for backend services (used by UI proxy configuration)
# This variable is exposed to the browser via Vite
VITE_API_URL=http://127.0.0.1:8000
VITE_KEYCLOAK_REALM=11id

# =============================================================================
# Unified Tunnel + External Access (single .env source)
# =============================================================================
# Cloudflare token (required for tunnel-start)
CLOUDFLARE_TUNNEL_TOKEN=

# Public domain and URLs
PUBLIC_DOMAIN=beta.elevenidllc.com
PUBLIC_URL=https://beta.elevenidllc.com
PUBLIC_API_URL=https://beta.elevenidllc.com
UI_BASE_URL=https://beta.elevenidllc.com

# Tunnel nginx routes to local UI server port
# - 3000: vite dev
# - 3002: vite preview (production build)
UI_DEV_PORT=3002

# Auth/OIDC URLs
OIDC_CLIENT_ID=marty-ui
OIDC_ISSUER_URL_INTERNAL=http://keycloak:8080/realms/11id
OIDC_ISSUER_URL_EXTERNAL=http://localhost:8180/realms/11id
OIDC_REDIRECT_URI=https://beta.elevenidllc.com/v1/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=https://beta.elevenidllc.com/

# Cookie and CORS settings
COOKIE_SECURE=true
COOKIE_SAMESITE=none
CORS_ORIGINS=https://beta.elevenidllc.com,http://localhost:9080,http://localhost:3000,http://localhost:5173
SESSION_COOKIE_DOMAIN=.elevenidllc.com
SESSION_SECRET=dev-session-secret-change-in-production

# Optional: Additional service URLs (if using separate microservices)
# VITE_ISSUER_API=http://localhost:8080
# VITE_VERIFIER_API=http://localhost:8081
# VITE_WALLET_API=http://localhost:8082

# =============================================================================
# gRPC Configuration
# =============================================================================
# Shared bearer token for intra-service gRPC authentication
GRPC_SERVICE_TOKEN=change_me_grpc_token
# TLS certificates for gRPC (production)
# GRPC_TLS_CERT=/etc/certs/server.crt
# GRPC_TLS_KEY=/etc/certs/server.key
# GRPC_TLS_CA_CERT=/etc/certs/ca.crt
GRPC_INSECURE_ALLOWED=true

# =============================================================================
# Flow / Verifier Service
# =============================================================================
# PEM-encoded signing key for OID4VP request objects
# VERIFIER_SIGNING_KEY_PEM=
# VERIFIER_SIGNING_KEY_FILE=./keys/verifier.pem
VERIFIER_CLIENT_ID=marty-verifier
NONCE_TTL_SECONDS=300
REDIS_DB_FLOW=1
FLOW_WEBHOOK_SECRET=change_me_flow_webhook_secret

# =============================================================================
# Notification Service
# =============================================================================
NOTIFICATION_WEBHOOK_SECRET=change_me_notification_webhook_secret
DIRECT_WEBHOOK_MAX_RETRIES=3
WEBHOOK_CIRCUIT_BREAKER_THRESHOLD=5
# NOTIFICATION_EVENT_INGEST_URL=http://event-stream:50051

# =============================================================================
# Gateway Service
# =============================================================================
RATE_LIMIT_RPM=120
RATE_LIMIT_BURST=20
# Cedar authorization policy paths
# CEDAR_SCHEMA_PATH=./policies/schema.cedarschema
# CEDAR_POLICIES_DIR=./policies/
# BILLING_SCHEMA_PATH=./policies/billing.cedarschema
# BILLING_POLICIES_DIR=./policies/billing/

# =============================================================================
# Auth Service (Extended)
# =============================================================================
AUTH_RATE_LIMIT_RPM=30
COOKIE_SAMESITE=Lax
# OIDC_CLIENT_SECRET=  # Confidential client secret (if not using public client)

# =============================================================================
# Device Registration
# =============================================================================
DEVICE_CHALLENGE_TTL=300

# =============================================================================
# Billing / Square (Extended)
# =============================================================================
# SQUARE_ENVIRONMENT=sandbox
# SQUARE_ACCESS_TOKEN=
# SQUARE_LOCATION_ID=
# SQUARE_WEBHOOK_SIGNATURE_KEY=
# SQUARE_PLAN_STARTER_ID=
# SQUARE_PLAN_PROFESSIONAL_ID=
# SQUARE_PLAN_ENTERPRISE_ID=

# =============================================================================
# Observability
# =============================================================================
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# =============================================================================
# Organization Identity
# =============================================================================
MARTY_ORG_ID=00000000-0000-0000-0000-000000000001
MARTY_ORG_ADMIN_EMAIL=admin@marty.demo
