# Demo OpenWallet SDK Environment Configuration
# Copy this file to .env and customize values for your environment

# =============================================================================
# Keycloak Admin Configuration
# =============================================================================
# Admin console credentials (for Keycloak management)
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=11id

# =============================================================================
# Google OAuth2 (Social Login)
# =============================================================================
# Create credentials at https://console.cloud.google.com/
# Authorized redirect URI: https://<PUBLIC_DOMAIN>/realms/11id/broker/google/endpoint
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# Keycloak Service Account
# =============================================================================
# Secret for the marty-api confidential client (used for token exchange)
MARTY_API_CLIENT_SECRET=marty-api-secret-change-in-production

# =============================================================================
# Credential Login (OID4VP)
# =============================================================================
# UUID of the OpenBadgeLogin presentation policy.
# Available policies (seeded by migrations):
#   50000000-...-000000000001  ElevenID org — SD-JWT MemberCredential
#   50000000-...-000000000002  Marty org   — SD-JWT Member Login Credential
#   50000000-...-000000000003  Marty org   — mDoc Membership ID
#   50000000-...-000000000004  Marty org   — Open Badge Verified Member Badge
CREDENTIAL_LOGIN_POLICY_ID=50000000-0000-0000-0000-000000000004
# Internal URL the flow service uses to call back after VP verification
AUTH_SERVICE_INTERNAL_URL=http://auth:8001

# Keycloak database password
KEYCLOAK_DB_PASSWORD=keycloak

# =============================================================================
# OIDC Client Configuration
# =============================================================================
OIDC_CLIENT_ID=marty-ui

# =============================================================================
# Demo Administrator User
# =============================================================================
DEMO_ADMIN_EMAIL=admin@marty.demo
DEMO_ADMIN_FIRST_NAME=Admin
DEMO_ADMIN_LAST_NAME=User
DEMO_ADMIN_PASSWORD=Admin123!

# Dedicated reviewer used by deterministic lifecycle tests.
DEMO_REVIEWER_EMAIL=reviewer@marty.demo
DEMO_REVIEWER_FIRST_NAME=Review
DEMO_REVIEWER_LAST_NAME=User
DEMO_REVIEWER_PASSWORD=Reviewer123!

# Canvas integration demo org admin, used by the Playwright demo recorder.
CANVAS_DEMO_ADMIN_EMAIL=canvas.admin@marty.demo
CANVAS_DEMO_ADMIN_FIRST_NAME=Canvas
CANVAS_DEMO_ADMIN_LAST_NAME=Demo Admin
CANVAS_DEMO_ADMIN_PASSWORD=CanvasAdmin123!

# =============================================================================
# Demo Applicant Users
# =============================================================================
# Shared password for all demo applicants
DEMO_APPLICANT_PASSWORD=Applicant123!

# Applicant 1
DEMO_APPLICANT1_EMAIL=john.doe@marty.demo
DEMO_APPLICANT1_FIRST_NAME=John
DEMO_APPLICANT1_LAST_NAME=Doe
DEMO_APPLICANT1_NATIONALITY=USA
DEMO_APPLICANT1_DOB=1985-03-15

# Applicant 2
DEMO_APPLICANT2_EMAIL=jane.smith@marty.demo
DEMO_APPLICANT2_FIRST_NAME=Jane
DEMO_APPLICANT2_LAST_NAME=Smith
DEMO_APPLICANT2_NATIONALITY=GBR
DEMO_APPLICANT2_DOB=1990-07-22

# Applicant 3
DEMO_APPLICANT3_EMAIL=carlos.garcia@marty.demo
DEMO_APPLICANT3_FIRST_NAME=Carlos
DEMO_APPLICANT3_LAST_NAME=Garcia
DEMO_APPLICANT3_NATIONALITY=ESP
DEMO_APPLICANT3_DOB=1978-11-08

# =============================================================================
# Database Configuration
# =============================================================================
# Applicant service database
APPLICANT_DB_PASSWORD=marty

# =============================================================================
# Session & Security
# =============================================================================
# Session cookie max age in seconds (default: 30 minutes)
SESSION_MAX_AGE=1800

# Environment: development or production
# Production enables strict cookie security (Secure, SameSite=Strict, __Host- prefix)
ENVIRONMENT=development

# =============================================================================
# Frontend Environment Variables (Vite)
# =============================================================================
# API URL for backend services (used by UI proxy configuration)
# This variable is exposed to the browser via Vite
VITE_API_URL=http://127.0.0.1:8000
VITE_KEYCLOAK_REALM=11id

# =============================================================================
# Unified Tunnel + External Access (single .env source)
# =============================================================================
# Cloudflare token (required for tunnel-start)
CLOUDFLARE_TUNNEL_TOKEN=

# Public domain and URLs
PUBLIC_DOMAIN=beta.elevenidllc.com
PUBLIC_URL=https://beta.elevenidllc.com
PUBLIC_API_URL=https://beta.elevenidllc.com
UI_BASE_URL=https://beta.elevenidllc.com

# Tunnel nginx routes to local UI server port
# - 3000: vite dev
# - 3002: vite preview (production build)
UI_DEV_PORT=3002

# Auth/OIDC URLs
OIDC_CLIENT_ID=marty-ui
OIDC_ISSUER_URL_INTERNAL=http://keycloak:8080/realms/11id
OIDC_ISSUER_URL_EXTERNAL=http://localhost:8180/realms/11id
OIDC_REDIRECT_URI=https://beta.elevenidllc.com/v1/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=https://beta.elevenidllc.com/

# Cookie and CORS settings
COOKIE_SECURE=true
COOKIE_SAMESITE=none
CORS_ORIGINS=https://beta.elevenidllc.com,http://localhost:9080,http://localhost:3000,http://localhost:5173
SESSION_COOKIE_DOMAIN=.elevenidllc.com
SESSION_SECRET=dev-session-secret-change-in-production

# Optional: Additional service URLs (if using separate microservices)
# VITE_ISSUER_API=http://localhost:8080
# VITE_VERIFIER_API=http://localhost:8081
# VITE_WALLET_API=http://localhost:8082

# =============================================================================
# gRPC Configuration
# =============================================================================
# Shared bearer token for intra-service gRPC authentication
GRPC_SERVICE_TOKEN=change_me_grpc_token
# TLS certificates for gRPC (production)
# GRPC_TLS_CERT=/etc/certs/server.crt
# GRPC_TLS_KEY=/etc/certs/server.key
# GRPC_TLS_CA_CERT=/etc/certs/ca.crt
GRPC_INSECURE_ALLOWED=true

# =============================================================================
# Flow / Verifier Service
# =============================================================================
# PEM-encoded signing key for OID4VP request objects
# OID4VP_ISSUER_PROFILE_ID=ip-marty-oid4vp-verifier
VERIFIER_CLIENT_ID=marty-verifier
NONCE_TTL_SECONDS=300
REDIS_DB_FLOW=1
FLOW_WEBHOOK_SECRET=change_me_flow_webhook_secret

# =============================================================================
# Notification Service
# =============================================================================
NOTIFICATION_WEBHOOK_SECRET=change_me_notification_webhook_secret
DIRECT_WEBHOOK_MAX_RETRIES=3
WEBHOOK_CIRCUIT_BREAKER_THRESHOLD=5
# NOTIFICATION_EVENT_INGEST_URL=http://event-stream:50051

# =============================================================================
# Gateway Service
# =============================================================================
RATE_LIMIT_RPM=120
RATE_LIMIT_BURST=20

# =============================================================================
# Canvas Credentials Integration
# =============================================================================
# Shared secret used to verify signed Canvas credential events.
CANVAS_CREDENTIALS_SHARED_SECRET=change_me_canvas_webhook_secret
CANVAS_CREDENTIALS_SIGNATURE_TOLERANCE_SECONDS=300
CANVAS_CREDENTIALS_PROVIDER=bridge
# bridge/sandbox mode posts to the beta-safe receiver. badgr_api uses the real Canvas Credentials API.
CANVAS_CREDENTIALS_PUBLISH_URL=
CANVAS_CREDENTIALS_STATUS_SYNC_URL=
CANVAS_CREDENTIALS_API_BASE_URL=https://api.badgr.io
# Additional exact public HTTPS Canvas Credentials API origins approved by operators.
CANVAS_CREDENTIALS_API_ORIGIN_ALLOWLIST=
# Real Canvas Credentials API tokens are stored by organization admins in the Canvas integration wizard.
# The standalone read-only contract checker may still use CANVAS_CREDENTIALS_API_TOKEN from an operator shell.
CANVAS_CREDENTIALS_ISSUER_ID=
CANVAS_CREDENTIALS_BADGECLASS_ID=
CANVAS_CREDENTIALS_ASSERTION_SCOPE=badgeclasses
CANVAS_CREDENTIALS_PROVENANCE_BASE_URL=https://beta.elevenidllc.com
CANVAS_CREDENTIALS_RECIPIENT_HASHED=true
CANVAS_CREDENTIALS_ALLOW_DUPLICATE_AWARDS=false
CANVAS_LTI_STATE_TTL_MINUTES=10
CANVAS_LTI_JWKS_TTL_MINUTES=1440
CANVAS_LTI_EXPERIENCE_BASE_URL=https://beta.elevenidllc.com
# Dedicated RS256 tool key. This is distinct from every credential issuer key.
CANVAS_LTI_TOOL_SIGNING_ORGANIZATION_ID=
CANVAS_LTI_TOOL_SIGNING_SERVICE_ID=
CANVAS_LTI_TOOL_SIGNING_KEY_REFERENCE=
# Required when portable Canvas is enabled: complete preflight inventory of
# credential issuer/document signer references. The LTI reference above must
# never appear in this comma-separated list.
CANVAS_CREDENTIAL_ISSUER_KEY_REFERENCES=
CANVAS_LTI_TOOL_ACTIVE_KID=
# Public RSA keys only. Retiring keys may include `retired_at`; never put d/p/q or other private fields here.
CANVAS_LTI_TOOL_PUBLIC_JWKS=
CANVAS_PORTABLE_INTEGRATION_ENABLED=false
# Comma-separated organization IDs admitted to the controlled hosted-Canvas pilot.
CANVAS_PILOT_ORGANIZATION_IDS=
# Compatibility-only custom webhook/AGS/NRPS event ingestion; keep false for portable v1.
CANVAS_LEGACY_EVENT_INGEST_ENABLED=false
# Operator-managed HTTPS origins for explicitly supported private self-managed Canvas installs.
CANVAS_PRIVATE_ORIGIN_ALLOWLIST=
# Exact HTTPS origins explicitly classified as self-managed Canvas. Endpoints are
# server-derived from these origins; do not put token/JWKS URLs in this value.
CANVAS_SELF_MANAGED_ORIGIN_ALLOWLIST=
# A readiness snapshot includes live KMS/DID verification and must be refreshed before this age.
CANVAS_BINDING_READINESS_MAX_AGE_SECONDS=900
# Authoritative evidence must be no older than 15 minutes when a Canvas badge is signed.
CANVAS_ISSUANCE_EVIDENCE_MAX_AGE_SECONDS=900
# Standalone PostgreSQL-backed synchronization worker. The processor must use module:function syntax.
CANVAS_BACKGROUND_ROSTER_BATCH_SIZE=500
CANVAS_BACKGROUND_ROSTER_MAX_SIZE=5000
CANVAS_SYNC_PROCESSOR=issuance.infrastructure.api.canvas_routes:process_authoritative_canvas_sync_target
CANVAS_SYNC_WORKER_BATCH_SIZE=10
CANVAS_SYNC_WORKER_LEASE_SECONDS=120
# Absolute deadline for one target, including all paginated Canvas reads.
CANVAS_SYNC_WORKER_JOB_TIMEOUT_SECONDS=600
CANVAS_SYNC_SCHEDULE_LIMIT=100
CANVAS_OAUTH_REVOCATION_BATCH_SIZE=25
# A five-second cycle keeps the database heartbeat inside the 120-second readiness window.
CANVAS_SYNC_WORKER_POLL_SECONDS=5
# Local sandbox URL relaxations. Keep false outside isolated dev/test stacks.
CANVAS_ALLOW_PRIVATE_BASE_URLS=false
CANVAS_ALLOW_HTTP_LOCALHOST_BASE_URLS=false

# Cedar authorization policy paths
# CEDAR_SCHEMA_PATH=./policies/schema.cedarschema
# CEDAR_POLICIES_DIR=./policies/

# =============================================================================
# Auth Service (Extended)
# =============================================================================
AUTH_RATE_LIMIT_RPM=30
COOKIE_SAMESITE=Lax
# OIDC_CLIENT_SECRET=  # Confidential client secret (if not using public client)

# =============================================================================
# Device Registration
# =============================================================================
DEVICE_CHALLENGE_TTL=300

# =============================================================================
# Observability
# =============================================================================
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# =============================================================================
# Organization Identity
# =============================================================================
MARTY_ORG_ID=00000000-0000-0000-0000-000000000001
MARTY_ORG_ADMIN_EMAIL=admin@marty.demo
MARTY_ORG_REVIEWER_EMAIL=reviewer@marty.demo
# Physical ICAO document issuance (required only when enabling that capability)
ICAO_DOCUMENT_SIGNER_URL=
ICAO_DOCUMENT_SIGNER_API_KEY=
PHYSICAL_DOCUMENT_ALLOW_SELF_SIGNED=false
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PHYSICAL_DOCUMENT_ARTIFACT_KEY=
PERSONALIZATION_BUREAU_URL=
PERSONALIZATION_BUREAU_API_KEY=
PERSONALIZATION_BUREAU_WEBHOOK_SECRET=
