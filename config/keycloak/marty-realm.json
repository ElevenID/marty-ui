{
  "realm": "marty",
  "enabled": true,
  "displayName": "Marty Trust Services",
  "displayNameHtml": "<div class=\"kc-logo-text\"><span>Marty Trust Services</span></div>",
  "loginTheme": "marty",
  "emailTheme": "marty",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "verifyEmail": false,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "none",
  "defaultSignatureAlgorithm": "RS256",
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "actionTokenGeneratedByAdminLifespan": 43200,
  "actionTokenGeneratedByUserLifespan": 300,
  "oauth2DeviceCodeLifespan": 600,
  "oauth2DevicePollingInterval": 5,
  "passwordPolicy": "length(8) and upperCase(1) and lowerCase(1) and digits(1) and specialChars(1)",
  "bruteForceProtected": false,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "organizationsEnabled": true,
  "roles": {
    "realm": [
      {
        "name": "administrator",
        "description": "Super administrators - cross-org access, can impersonate any user",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "vendor",
        "description": "Vendor organization admins - manage their org, API keys, invite applicants",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "applicant",
        "description": "Travel document applicants - citizens seeking travel documents",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "default-roles-marty",
        "description": "${role_default-roles}",
        "composite": true,
        "composites": {
          "realm": ["applicant"]
        },
        "clientRole": false
      }
    ]
  },
  "defaultRole": {
    "name": "default-roles-marty",
    "description": "${role_default-roles}",
    "composite": true,
    "composites": {
      "realm": ["applicant"]
    },
    "clientRole": false
  },
  "requiredCredentials": ["password"],
  "users": [
    {
      "username": "admin@marty.demo",
      "email": "admin@marty.demo",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "Admin123!",
          "temporary": false
        }
      ],
      "realmRoles": ["administrator"],
      "attributes": {
        "user_type": ["administrator"]
      }
    },
    {
      "username": "vendor@marty.demo",
      "email": "vendor@marty.demo",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Vendor",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "Vendor123!",
          "temporary": false
        }
      ],
      "realmRoles": ["vendor"],
      "attributes": {
        "user_type": ["vendor"],
        "organization_name": ["Demo Vendor Org"]
      }
    },
    {
      "username": "john.doe@marty.demo",
      "email": "john.doe@marty.demo",
      "emailVerified": true,
      "enabled": true,
      "firstName": "John",
      "lastName": "Doe",
      "credentials": [
        {
          "type": "password",
          "value": "Applicant123!",
          "temporary": false
        }
      ],
      "realmRoles": ["applicant"],
      "attributes": {
        "user_type": ["applicant"],
        "nationality": ["USA"],
        "date_of_birth": ["1985-03-15"]
      }
    },
    {
      "username": "jane.smith@marty.demo",
      "email": "jane.smith@marty.demo",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Jane",
      "lastName": "Smith",
      "credentials": [
        {
          "type": "password",
          "value": "Applicant123!",
          "temporary": false
        }
      ],
      "realmRoles": ["applicant"],
      "attributes": {
        "user_type": ["applicant"],
        "nationality": ["GBR"],
        "date_of_birth": ["1990-07-22"]
      }
    },
    {
      "username": "carlos.garcia@marty.demo",
      "email": "carlos.garcia@marty.demo",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Carlos",
      "lastName": "Garcia",
      "credentials": [
        {
          "type": "password",
          "value": "Applicant123!",
          "temporary": false
        }
      ],
      "realmRoles": ["applicant"],
      "attributes": {
        "user_type": ["applicant"],
        "nationality": ["ESP"],
        "date_of_birth": ["1978-11-08"]
      }
    },
    {
      "username": "verifier@marty.demo",
      "email": "verifier@marty.demo",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Verifier",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "Verifier123!",
          "temporary": false
        }
      ],
      "realmRoles": ["vendor"],
      "attributes": {
        "user_type": ["verifier"]
      }
    }
  ],
  "clients": [
    {
      "clientId": "marty-ui",
      "name": "Marty Trust Services UI",
      "description": "Frontend application for Marty Trust Services",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "http://localhost:9080/*",
        "${UI_BASE_URL}/*",
        "http://host.docker.internal:9080/*",
        "https://*.marty.demo/*"
      ],
      "webOrigins": [
        "http://localhost:9080",
        "${UI_BASE_URL}",
        "http://host.docker.internal:9080",
        "https://*.marty.demo"
      ],
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:9080/*##${UI_BASE_URL}/*##http://host.docker.internal:9080/*##https://*.marty.demo/*"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles",
        "marty-user-attributes",
        "organization"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access"
      ]
    },
    {
      "clientId": "marty-api",
      "name": "Marty Trust Services API",
      "description": "Backend API for Marty Trust Services",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "${MARTY_API_CLIENT_SECRET:-marty-api-secret-change-in-production}",
      "bearerOnly": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "openid",
      "description": "OpenID Connect scope",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {}
        }
      ]
    },
    {
      "name": "profile",
      "description": "OpenID Connect built-in scope: profile",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "${profileScopeConsentText}"
      },
      "protocolMappers": [
        {
          "name": "given name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "firstName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "given_name",
            "jsonType.label": "String"
          }
        },
        {
          "name": "family name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "lastName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "family_name",
            "jsonType.label": "String"
          }
        },
        {
          "name": "full name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "name": "email",
      "description": "OpenID Connect built-in scope: email",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "${emailScopeConsentText}"
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "email",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        },
        {
          "name": "email verified",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "emailVerified",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email_verified",
            "jsonType.label": "boolean"
          }
        }
      ]
    },
    {
      "name": "roles",
      "description": "OpenID Connect scope for add user roles to the access token",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "true",
        "consent.screen.text": "${rolesScopeConsentText}"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "foo",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        },
        {
          "name": "client roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "foo",
            "access.token.claim": "true",
            "claim.name": "resource_access.${client_id}.roles",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        },
        {
          "name": "audience resolve",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-resolve-mapper",
          "consentRequired": false,
          "config": {}
        }
      ]
    },
    {
      "name": "offline_access",
      "description": "OpenID Connect built-in scope: offline_access",
      "protocol": "openid-connect",
      "attributes": {
        "consent.screen.text": "${offlineAccessScopeConsentText}",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "address",
      "description": "OpenID Connect built-in scope: address",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "${addressScopeConsentText}"
      }
    },
    {
      "name": "phone",
      "description": "OpenID Connect built-in scope: phone",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "${phoneScopeConsentText}"
      }
    },
    {
      "name": "marty-user-attributes",
      "description": "Marty-specific user attributes",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "Access to your Marty profile information"
      },
      "protocolMappers": [
        {
          "name": "user_type",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "user_type",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "user_type",
            "jsonType.label": "String"
          }
        },
        {
          "name": "nationality",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "nationality",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "nationality",
            "jsonType.label": "String"
          }
        },
        {
          "name": "date_of_birth",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "date_of_birth",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "date_of_birth",
            "jsonType.label": "String"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "name": "organization",
      "description": "Organization membership scope for multi-tenant access",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "Access to your organization membership"
      },
      "protocolMappers": [
        {
          "name": "organization",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-organization-membership-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "organization",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "organization_name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "organization_name",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "organization_name",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "scopeMappings": [
    {
      "clientScope": "marty-user-attributes",
      "roles": ["administrator", "vendor", "applicant"]
    },
    {
      "clientScope": "organization",
      "roles": ["administrator", "vendor", "applicant"]
    }
  ],
  "browserSecurityHeaders": {
    "contentSecurityPolicyReportOnly": "",
    "xContentTypeOptions": "nosniff",
    "xRobotsTag": "none",
    "xFrameOptions": "ALLOW-FROM http://localhost:9080",
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self' http://localhost:*; object-src 'none';",
    "xXSSProtection": "1; mode=block",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains"
  },
  "smtpServer": {
    "host": "mailhog",
    "port": "1025",
    "from": "noreply@marty.demo",
    "fromDisplayName": "Marty Trust Services",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  },
  "eventsEnabled": true,
  "eventsExpiration": 900,
  "eventsListeners": ["jboss-logging"],
  "enabledEventTypes": [
    "LOGIN",
    "LOGIN_ERROR",
    "LOGOUT",
    "LOGOUT_ERROR",
    "REGISTER",
    "REGISTER_ERROR",
    "CODE_TO_TOKEN",
    "CODE_TO_TOKEN_ERROR",
    "CLIENT_LOGIN",
    "CLIENT_LOGIN_ERROR",
    "REFRESH_TOKEN",
    "REFRESH_TOKEN_ERROR",
    "REVOKE_GRANT",
    "UPDATE_EMAIL",
    "UPDATE_PASSWORD",
    "UPDATE_PROFILE"
  ],
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true,
  "internationalizationEnabled": true,
  "supportedLocales": ["en", "es", "fr", "de"],
  "defaultLocale": "en"
}
