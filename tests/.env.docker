# Docker Test Environment Configuration
# Used by Playwright tests when running inside Docker containers

# URLs (using Docker service names for internal network)
BASE_URL=http://ui:80
API_URL=http://oid4vc-api:8000
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_ADMIN_URL=http://keycloak:8080/admin
WALLET_URL=http://wallet-simulator:80
MAILHOG_URL=http://mailhog:8025

# External URLs (for browser redirects that happen outside Docker)
OIDC_ISSUER_URL=http://localhost:8180/realms/marty

# Test Provider (mailhog for Docker, mock for CI without MailHog)
TEST_PROVIDER=mailhog

# Keycloak Admin
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=marty

# CI Flag
CI=true

# Seeded Test Users (same as .env.test)
TEST_ADMIN_EMAIL=admin@marty.demo
TEST_ADMIN_PASSWORD=Admin123!
TEST_VENDOR_EMAIL=vendor@marty.demo
TEST_VENDOR_PASSWORD=Vendor123!
TEST_APPLICANT1_EMAIL=john.doe@marty.demo
TEST_APPLICANT1_PASSWORD=Applicant123!
