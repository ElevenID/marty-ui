# syntax=docker/dockerfile:1
# Pytest runner for marty-ui API tests
# Builds on the same base as the API to ensure compatibility
# Optimized with BuildKit cache mounts

FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements and install dependencies with BuildKit cache
COPY marty-ui/src/requirements.txt .
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-cache-dir -r requirements.txt

# Install additional test dependencies with BuildKit cache
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-cache-dir \
    pytest-cov==4.1.0 \
    pytest-xdist==3.5.0 \
    pytest-html==4.1.1 \
    jwcrypto==1.5.0

# Copy MMF framework
COPY marty-microservices-framework/ /app/marty-microservices-framework/
ENV PYTHONPATH="${PYTHONPATH}:/app/marty-microservices-framework"

# Copy application code
COPY marty-ui/src/ /app/src/

# Copy all tests
COPY tests/ /app/tests/

# Working directory for tests
WORKDIR /app

# Default command: run all tests
CMD ["pytest", "tests/unit/api_keys/", "-v", "--tb=short"]
