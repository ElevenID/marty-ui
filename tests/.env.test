# Test Environment Configuration
# Used by Playwright tests when running against Docker-based test environment

# URLs
BASE_URL=http://localhost:9080
API_URL=http://localhost:8000
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_ADMIN_URL=http://localhost:8180/admin
WALLET_URL=http://localhost:9081
MAILHOG_URL=http://localhost:8025

# Keycloak Admin
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=marty

# Seeded Test Users
# Admin user (super admin - cross-org access)
TEST_ADMIN_EMAIL=admin@marty.demo
TEST_ADMIN_PASSWORD=Admin123!
TEST_ADMIN_FIRST_NAME=Admin
TEST_ADMIN_LAST_NAME=User
TEST_ADMIN_ROLE=administrator

# Vendor user (org admin)
TEST_VENDOR_EMAIL=vendor@marty.demo
TEST_VENDOR_PASSWORD=Vendor123!
TEST_VENDOR_FIRST_NAME=Vendor
TEST_VENDOR_LAST_NAME=Admin
TEST_VENDOR_ROLE=vendor
TEST_VENDOR_ORG=Demo Vendor Org

